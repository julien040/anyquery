---
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const { fullBleed = false } = Astro.props;

// Fetch GitHub stars at build time. In dev we skip the request and use the
// fallback so HMR/page navigations don't burn through the unauthenticated
// rate limit (60 req/hour per IP).
const STARS_FALLBACK = 1700;

async function getStars(): Promise<number> {
    if (import.meta.env.DEV) return STARS_FALLBACK;
    try {
        const res = await fetch(
            "https://api.github.com/repos/julien040/anyquery",
            {
                headers: {
                    Accept: "application/vnd.github+json",
                    "User-Agent": "anyquery-website-build",
                },
            },
        );
        if (!res.ok) return STARS_FALLBACK;
        const data = await res.json();
        return typeof data.stargazers_count === "number"
            ? data.stargazers_count
            : STARS_FALLBACK;
    } catch {
        return STARS_FALLBACK;
    }
}

const stars = await getStars();
// 1234 -> "1.2k"
const starsLabel =
    stars >= 1000
        ? (stars / 1000).toFixed(1).replace(/\.0$/, "") + "k"
        : String(stars);
---

<nav class="relative z-[5] font-ui">
    <div
        class:list={[
            "flex flex-col items-center justify-between gap-4 py-[18px] md:flex-row",
            fullBleed && "wrap",
        ]}
    >
        <Astronav>
            <div class="flex w-full items-center justify-between md:w-auto">
                <a
                    href="/"
                    class="font-display text-[28px] leading-none tracking-[-0.02em] text-ink"
                    aria-label="Anyquery home"
                    >any<em class="italic text-peach-700">query</em></a
                >
                <MenuIcon class="aq-menu-icon" />
            </div>
            <MenuItems
                class="mx-auto hidden flex-col gap-3 py-3 text-sm text-ink-2 sm:flex md:flex-row md:gap-7 md:py-0"
            >
                <a href="/llm" class="transition-colors hover:text-ink"
                    >MCP • AI</a
                >
                <a href="/integrations" class="transition-colors hover:text-ink"
                    >Integrations</a
                >
                <a href="/docs" class="transition-colors hover:text-ink">Docs</a
                >
                <a href="/queries" class="transition-colors hover:text-ink"
                    >Hub</a
                >
                <a href="/recipes" class="transition-colors hover:text-ink"
                    >Guides</a
                >
            </MenuItems>
            <div class="hidden items-center gap-4 md:flex">
                <a
                    href="https://github.com/julien040/anyquery"
                    class="inline-flex items-center gap-1.5 text-ink-2 transition-colors hover:text-ink"
                    aria-label={`Anyquery on GitHub (${stars} stars)`}
                >
                    <span class="text-sm tabular-nums">{starsLabel} </span>
                    <svg
                        class="inline-block h-5 w-5 hover:text-yellow-600 hover:rotate-180 transition-all"
                        viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg"
                        ><path
                            fill="currentColor"
                            d="m12 17.27l4.15 2.51c.76.46 1.69-.22 1.49-1.08l-1.1-4.72l3.67-3.18c.67-.58.31-1.68-.57-1.75l-4.83-.41l-1.89-4.46c-.34-.81-1.5-.81-1.84 0L9.19 8.63l-4.83.41c-.88.07-1.24 1.17-.57 1.75l3.67 3.18l-1.1 4.72c-.2.86.73 1.54 1.49 1.08z"
                        ></path></svg
                    >
                    <svg
                        fill="none"
                        height="24"
                        viewBox="0 0 24 25"
                        width="24"
                        xmlns="http://www.w3.org/2000/svg"
                        ><path
                            d="m12 2.5c-1.3132 0-2.61358.25866-3.82684.7612-1.21325.50255-2.31564 1.23915-3.24423 2.16773-1.87536 1.87537-2.92893 4.41891-2.92893 7.07107 0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85v2.74c0 .27.16.59.67.5 3.97-1.34 6.83-5.08 6.83-9.5 0-1.3132-.2587-2.61358-.7612-3.82683-.5026-1.21326-1.2391-2.31565-2.1677-3.24424-.9286-.92858-2.031-1.66518-3.2443-2.16773-1.2132-.50254-2.5136-.7612-3.8268-.7612z"
                            fill="currentColor"></path></svg
                    ></a
                >
                <a href="/docs/#installation" class="btn btn-sm">Install</a>
            </div>
        </Astronav>
    </div>
</nav>
