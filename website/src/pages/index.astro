    const $ = (id: string) => document.getElementById(id);

    /* ==============================================================
       Kinetic hero — cycle words & result card
    ============================================================== */
    const slot = $("slot")!;
    const slotWord = $("slotWord")!;
    const slotDot = $("slotDot")!;
    const rc = $("resultCard")!;
    const rcTable = $("rcTable")!;
    const rcTitle = $("rcTitle")!;
    const rcSq = $("rcSq")!;
    const rcTime = $("rcTime")!;
    const rcSub = $("rcSub")!;
    const rcRows2 = $("rcRows2")!;

    function paintResult(key: string) {
        const s = SOURCES[key];
        const colorVar = `var(--color-${s.color})`;
        slotDot.style.background = colorVar;
        slot.style.background = `color-mix(in oklab, ${colorVar} 40%, var(--color-paper-2))`;
        rcSq.style.background = colorVar;
        rc.style.background = `linear-gradient(180deg, color-mix(in oklab, ${colorVar} 18%, var(--color-paper)) 0%, var(--color-paper) 40%)`;
        rcTitle.textContent = s.table;
        rcTime.textContent = s.time;
        rcSub.textContent = "6 of " + s.rows.toLocaleString() + " rows";
        rcRows2.textContent = s.rows.toLocaleString() + " rows";

        const cols = s.cols;
        rcTable.innerHTML = `
      <thead><tr>
        <th>#</th>
        <th>${cols[0]}</th>
        <th>${cols[1]}</th>
        <th style="text-align:right;padding-right:18px">${cols[2]}</th>
      </tr></thead>
      <tbody>${s.data
          .map(
              (r, i) => `
        <tr>
          <td class="idx">${String(i + 1).padStart(2, "0")}</td>
          <td>${r.a}</td>
          <td class="c-meta" style="text-align:left;width:auto;padding-right:12px">${r.b}</td>
          <td style="text-align:right;padding-right:18px;width:90px"><span class="pill" style="background:var(--color-${r.p});color:var(--color-ink)">${r.pill}</span></td>
        </tr>
      `,
          )
          .join("")}</tbody>`;
    }

    let ki = 0;
    paintResult(ORDER[0]);

    function cycle() {
        ki = (ki + 1) % ORDER.length;
        const key = ORDER[ki];
        const s = SOURCES[key];

        slot.classList.add("leaving");
        rc.classList.toggle("tilt");
        setTimeout(() => {
            slotWord.textContent = s.word;
            slot.classList.remove("leaving");
            slot.classList.add("entering");
            paintResult(key);
            requestAnimationFrame(() => slot.classList.remove("entering"));
        }, 380);
    }
    if (!reduceMotion) {
        setInterval(cycle, 2400);
    }

    /* ==============================================================
       Playground — tabs of same-dialect queries
    ============================================================== */
    const tabsEl = $("pgTabs")!;
    const sqlEl = $("pgSql")!;
    const tableEl = $("pgTable")!;
    const footT = $("pgFootTime")!;
    const footR = $("pgFootRows")!;

    function hl(code: string) {
        return code
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/(--[^\n]*)/g, '<span class="sql-c">$1</span>')
            .replace(
                /\b(SELECT|FROM|WHERE|GROUP BY|ORDER BY|JOIN|ON|UPDATE|SET|INSERT INTO|VALUES|DELETE|LIMIT|AND|AS|COUNT|SUM|AVG)\b/g,
                '<span class="sql-k">$1</span>',
            )
            .replace(/('[^']*')/g, '<span class="sql-s">$1</span>')
            .replace(
                /\b(read_parquet|google_sheets|date|now)\b/g,
                '<span class="sql-b">$1</span>',
            );
    }

    function selectPg(key: string, btn?: HTMLElement) {
        document
            .querySelectorAll(".pg-tab")
            .forEach((b) => b.classList.remove("on"));
        if (btn) btn.classList.add("on");
        const s = SOURCES[key];
        sqlEl.innerHTML = hl(s.pg);
        const cols = s.cols;
        tableEl.innerHTML = `
      <thead><tr>${cols.map((c) => `<th>${c}</th>`).join("")}</tr></thead>
      <tbody>${s.data
          .slice(0, 5)
          .map(
              (r) => `
        <tr>
          <td>${r.a}</td>
          <td>${r.b}</td>
          <td><span class="cell-pill" style="background:var(--color-${r.p})">${r.pill}</span></td>
        </tr>
      `,
          )
          .join("")}</tbody>`;
        footT.textContent = s.time;
        footR.textContent = s.rows.toLocaleString() + " rows total";
    }

    ORDER.forEach((key, i) => {
        const s = SOURCES[key];
        const b = document.createElement("button");
        b.className = "pg-tab" + (i === 0 ? " on" : "");
        b.innerHTML = `<span class="sq" style="background:var(--color-${s.color})"></span>${s.word}`;
        b.onclick = () => selectPg(key, b);
        tabsEl.appendChild(b);
    });
    selectPg("github");

