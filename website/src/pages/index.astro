    ============================================================== */
    const CMD: Record<string, string> = {
        mac: "brew install anyquery",
        linux: `echo "deb [trusted=yes] https://apt.julienc.me/ /" | sudo tee /etc/apt/sources.list.d/anyquery.list
sudo apt update
sudo apt install anyquery`,
        win: "choco install anyquery",
    };
    const osCmd = $("osCmd")!;
    document.querySelectorAll<HTMLButtonElement>(".os-tab").forEach((b) => {
        b.onclick = () => {
            document
                .querySelectorAll(".os-tab")
                .forEach((x) => x.classList.remove("on"));
            b.classList.add("on");
            osCmd.textContent = CMD[b.dataset.os!];
        };
    });
    // auto-detect
    (function () {
        const p = (navigator.userAgent || "").toLowerCase();
        let os = "mac";
        if (p.includes("win")) os = "win";
        else if (p.includes("linux") && !p.includes("android")) os = "linux";
        const b = document.querySelector<HTMLButtonElement>(
            `.os-tab[data-os="${os}"]`,
        );
        if (b) b.click();
    })();

    const copyBtn = $("copyBtn");
    if (copyBtn) {
        copyBtn.addEventListener("click", () => {
            navigator.clipboard?.writeText(osCmd.textContent || "");
            copyBtn.textContent = "Copied";
            setTimeout(() => (copyBtn.textContent = "Copy"), 1400);
        });
    }
</script>
