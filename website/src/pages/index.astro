---
import Main from "../layouts/main.astro";
---

<Main
    title="Anyquery — One SQL engine for everything you already use"
    description="Run SQL on GitHub, Notion, Spotify, Gmail, Airtable, Google Sheets, CSVs, Parquet, logs — and 40+ more. One binary, one dialect. Then hand it to an LLM over MCP. Open source, AGPL-3.0."
    fullBleed={true}
    footnote="Trademarks are the property of their respective owners. Anyquery is not affiliated with any of the companies or projects mentioned. Illustrative data shown."
>
    <div itemscope itemtype="https://schema.org/WebSite">
        <link itemprop="url" href="https://anyquery.dev" />
        <meta itemprop="name" content="Anyquery" />
        <meta
            itemprop="description"
            content="SQL queries for any data source (e.g. GSheets, logs, JSON, Salesforce, Notion, etc.). Open source and free."
        />
    </div>

    <!-- ============ HERO ============ -->
    <section class="relative overflow-hidden pt-8 pb-20">
        <div
            class="absolute inset-[-40px] z-0 pointer-events-none"
            aria-hidden="true"
        >
            <div
                class="absolute h-[480px] w-[480px] -right-20 top-20 rounded-full bg-lavender opacity-80 blur-[40px]"
            >
            </div>
            <div
                class="absolute h-[360px] w-[360px] -left-24 top-72 rounded-full bg-peach opacity-80 blur-[40px]"
            >
            </div>
            <div
                class="absolute h-[260px] w-[260px] right-[260px] top-[520px] rounded-full bg-pistachio opacity-55 blur-[40px]"
            >
            </div>
        </div>
        <div class="wrap z-[2]">
            <h1
                class="mt-6 font-display text-[clamp(62px,8vw,80px)] font-normal leading-[0.96] tracking-[-0.035em] text-ink"
            >
                One <span class="italic">SQL</span> engine<br />
                for <span class="hl-underline">everything</span><br />
                you already <span class="italic">use.</span>
            </h1>

            <div
                class="mt-7 flex flex-wrap items-baseline gap-x-[18px] gap-y-3.5 font-mono text-[clamp(20px,2.6vw,24px)]"
                aria-live="polite"
                id="kinetic"
            >
                <span class="font-medium text-syn-keyword">SELECT</span>
                <span class="text-syn-operator">*</span>
                <span class="font-medium text-syn-keyword">FROM</span>
                <span
                    id="slot"
                    class="kin-slot relative inline-flex min-h-[52px] min-w-[280px] items-center gap-2.5 overflow-hidden rounded-full bg-paper-2 px-4 pt-1.5 pb-2 inset-shadow-hair"
                >
                    <span
                        id="slotDot"
                        class="h-3.5 w-3.5 shrink-0 rounded bg-pistachio"
                    ></span>
                    <span
                        id="slotWord"
                        class="kin-word inline-block font-display text-[1.2em] italic tracking-[-0.02em] text-ink"
                        >github</span
                    >
                </span>
                <span class="text-ink-3">;</span>
            </div>

            <div
                class="relative mt-1 grid grid-cols-1 items-center gap-8 md:grid-cols-[1.1fr_0.9fr]"
            >
                <div>
                    <p
                        class="max-w-[560px] text-base md:text-lg leading-[1.45] text-ink-2"
                    >
                        Anyquery turns <b class="font-medium text-ink"
                            >GitHub, Notion, Spotify, Gmail, Airtable, Google
                            Sheets, CSVs, Parquet, logs</b
                        > — and forty more — into queryable tables. One binary, one
                        dialect, one way of asking questions. Then hand it to an LLM
                        so Claude can answer them for you.
                    </p>
                    <div class="mt-7 flex flex-wrap items-center gap-3">
                        <a class="btn" href="#install">Get anyquery →</a>
                        <a class="btn btn-ghost" href="#engine"
                            >See it in action</a
                        >
                        <div
                            class="inline-flex items-center gap-2.5 rounded-full bg-ink px-4 py-3 font-mono text-[13px] text-paper"
                        >
                            <span class="opacity-50">$</span><span
                                >brew install anyquery</span
                            >
                        </div>
                    </div>
                    <p class="mt-3.5 text-sm text-ink-3">
                        Free & open-source · AGPL-3.0 · macOS · Linux · Windows
                    </p>
                </div>

                <div
                    id="resultCard"
                    class="result-card relative min-h-[360px] overflow-hidden rounded-lg bg-paper shadow-lift inset-shadow-hair"
                >
                    <div
                        class="flex items-center justify-between border-b border-ink/15 px-[18px] py-3.5 text-[13px] text-ink-2"
                    >
                        <span
                            class="inline-flex items-center gap-2 font-mono text-[13px] font-medium text-ink"
                        >
                            <span
                                id="rcSq"
                                class="h-3.5 w-3.5 rounded bg-pistachio"></span>
                            <span id="rcTitle">github_starred_repos</span>
                        </span>
                        <span id="rcSub" class="text-sm text-ink-3"
                            >6 of 274 rows</span
                        >
                    </div>
                    <table class="rc-table" id="rcTable"></table>
                    <div
                        class="flex justify-between border-t border-ink/15 px-[18px] py-2.5 font-mono text-[11px] text-ink-3"
                    >
                        <span
                            class="inline-flex items-center gap-1.5 text-pistachio-700"
                            ><span
                                class="h-[7px] w-[7px] rounded-full bg-pistachio-700"
                            ></span><span id="rcTime">27ms</span></span
                        >
                        <span id="rcRows2">274 rows</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============ ONE ENGINE ============ -->
    <section class="relative bg-paper py-24" id="engine">
        <div class="wrap">
            <div
                class="grid grid-cols-1 items-start gap-12 md:grid-cols-[1.1fr_1fr] md:gap-[72px]"
            >
                <div>
                    <h2
                        class="mt-3.5 mb-7 max-w-[20ch] font-display text-[clamp(36px,4vw,52px)] font-normal leading-[1.06] tracking-[-0.03em]"
                    >
                        The same <em class="italic text-peach-700">SELECT</em>,
                        no matter where the data lives.
                    </h2>
                    <p
                        class="max-w-[52ch] text-base md:text-lg leading-[1.45] text-ink-2"
                    >
                        You don't learn the Notion API. You don't write a Gmail
                        scraper. You don't install four CLI tools. You write <code
                            class="aq-code">SELECT</code
                        > and Anyquery does the rest — across 40+ services and every
                        file on disk.
                    </p>

                    <div
                        class="mt-14 grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3"
                    >
                        <div
                            class="flex flex-col gap-3 rounded-lg bg-paper p-6 inset-shadow-hair"
                        >
                            <div
                                class="flex h-10 w-10 items-center justify-center rounded-[10px] bg-pistachio font-display text-[22px] leading-none text-ink"
                            >
                                ⟨⟩
                            </div>
                            <h3
                                class="text-base font-medium tracking-[-0.01em]"
                            >
                                One dialect, 40+ sources
                            </h3>
                            <p class="text-sm leading-[1.5] text-ink-2">
                                Built on SQLite. Everything from GitHub to
                                Parquet looks like a table. <code
                                    class="aq-code">JOIN</code
                                > them freely.
                            </p>
                        </div>
                        <div
                            class="flex flex-col gap-3 rounded-lg bg-paper p-6 inset-shadow-hair"
                        >
                            <div
                                class="flex h-10 w-10 items-center justify-center rounded-[10px] bg-butter font-display text-[22px] leading-none text-ink"
                            >
                                ⇌
                            </div>
                            <h3
                                class="text-base font-medium tracking-[-0.01em]"
                            >
                                BI tools just work
                            </h3>
                            <p class="text-sm leading-[1.5] text-ink-2">
                                Exposes the MySQL wire protocol, so Metabase,
                                Tableau, Drizzle, and Looker connect in one
                                click.
                            </p>
                        </div>
                        <div
                            class="flex flex-col gap-3 rounded-lg bg-paper p-6 inset-shadow-hair"
                        >
                            <div
                                class="flex h-10 w-10 items-center justify-center rounded-[10px] bg-peach font-display text-[22px] leading-none text-ink"
                            >
                                ♁
                            </div>
                            <h3
                                class="text-base font-medium tracking-[-0.01em]"
                            >
                                Local-first, yours
                            </h3>
                            <p class="text-sm leading-[1.5] text-ink-2">
                                Runs on your laptop. No cloud, no pipeline, no
                                ETL. Your API tokens never leave the machine.
                            </p>
                        </div>
                        <div
                            class="flex flex-col gap-3 rounded-lg bg-paper p-6 inset-shadow-hair"
                        >
                            <div
                                class="flex h-10 w-10 items-center justify-center rounded-[10px] bg-lavender font-display text-[22px] leading-none text-ink"
                            >
                                ✱
                            </div>
                            <h3
                                class="text-base font-medium tracking-[-0.01em]"
                            >
                                Write back, too
                            </h3>
                            <p class="text-sm leading-[1.5] text-ink-2">
                                <code class="aq-code">INSERT</code>, <code
                                    class="aq-code">UPDATE</code
                                >, and <code class="aq-code">DELETE</code> on Notion,
                                Airtable, and Google Sheets like they were Postgres.
                            </p>
                        </div>
                        <div
                            class="flex flex-col gap-3 rounded-lg bg-paper p-6 inset-shadow-hair"
                        >
                            <div
                                class="flex h-10 w-10 items-center justify-center rounded-[10px] bg-sky font-display text-[22px] leading-none text-ink"
                            >
                                ◎
                            </div>
                            <h3
                                class="text-base font-medium tracking-[-0.01em]"
                            >
                                Query hub included
                            </h3>
                            <p class="text-sm leading-[1.5] text-ink-2">
                                Re-use hundreds of community queries without
                                writing SQL — from "close my Chrome tabs" to
                                "summarise my week".
                            </p>
                        </div>
                        <div
                            class="flex flex-col gap-3 rounded-lg bg-paper p-6 inset-shadow-hair"
                        >
                            <div
                                class="flex h-10 w-10 items-center justify-center rounded-[10px] bg-rose font-display text-[22px] leading-none text-ink"
                            >
                                ✺
                            </div>
                            <h3
                                class="text-base font-medium tracking-[-0.01em]"
                            >
                                Not just SQL
                            </h3>
                            <p class="text-sm leading-[1.5] text-ink-2">
                                Prefer PRQL? Kusto (PQL)? We support those too.
                                The engine doesn't care.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Playground -->
                <div
                    class="sticky top-6 rounded-xl bg-paper-2 p-5 inset-shadow-hair"
                    id="playground"
                >
                    <div class="mb-3.5 flex flex-wrap gap-1.5" id="pgTabs">
                    </div>
                    <div class="pg-sql" id="pgSql"></div>
                    <div class="pg-out">
                        <table id="pgTable"></table>
                        <div class="pg-foot">
                            <span id="pgFootTime">27ms</span>
                            <span id="pgFootRows">5 rows</span>
                        </div>
                    </div>
                    <p class="mt-3 text-center text-sm text-ink-3">
                        ↑ click a source to change the query — same dialect,
                        different data
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ============ MCP / LLM ============ -->
    <section class="relative bg-paper-3 py-24" id="mcp">
        <div class="wrap">
            <div
                class="grid grid-cols-1 items-center gap-10 md:grid-cols-[1.1fr_0.9fr] md:gap-16"
            >
                <div>
                    <h2
                        class="mt-4 mb-6 font-display text-[clamp(36px,4vw,52px)] font-normal leading-[1.06] tracking-[-0.03em]"
                    >
                        Give <em class="italic text-lavender-700">Claude</em> SQL
                        access<br />to the tools you already use.
                    </h2>
                    <p class="md:text-lg text-base text-ink-2">
                        Anyquery ships as an <b class="font-medium text-ink"
                            >MCP server</b
                        >. Claude Desktop, ChatGPT, Cursor, TypingMind and any
                        MCP-aware client can ask it questions in plain English —
                        and Anyquery answers with real data from your Spotify
                        history, your Apple Reminders, your Notion pages, your
                        Gmail inbox.
                    </p>
                    <p class="mt-3.5 md:text-lg text-ink-2">
                        One command: <code class="aq-code">anyquery mcp</code>.
                        No wrappers. No prompt gymnastics.
                    </p>
                    <div class="mt-6 flex flex-wrap items-center gap-3">
                        <a class="btn" href="/llm">Connect to Claude</a>
                        <a
                            class="btn btn-ghost"
                            href="https://modelcontextprotocol.io"
                            >What is MCP?</a
                        >
                    </div>
                </div>

                <div
                    class="relative min-h-[440px] rounded-xl bg-paper p-7 inset-shadow-hair"
                >
                    <div class="flex flex-col gap-3">
                        <div
                            class="max-w-[85%] self-end rounded-[18px] rounded-br-[6px] bg-ink px-4 py-3 text-sm leading-[1.45] text-paper"
                        >
                            Which of my starred GitHub repos were last updated
                            before 2023? I want to spring-clean.
                        </div>
                        <div
                            class="max-w-[85%] self-start rounded-[18px] rounded-bl-[6px] bg-lavender px-4 py-3 text-sm leading-[1.45] text-ink"
                        >
                            Let me check your stars via Anyquery.
                            <span
                                class="mt-2 block break-words rounded-lg bg-ink/[0.06] px-2.5 py-2 font-mono text-[11px] text-ink-2"
                                ><span class="font-medium text-lavender-700"
                                    >anyquery.query</span
                                > · <span class="sql-k">SELECT</span> name, pushed_at
                                <span class="sql-k">FROM</span> github_stars_from_user(<span
                                    class="sql-s">'you'</span
                                >) <span class="sql-k">WHERE</span> pushed_at &lt;
                                <span class="sql-s">'2023-01-01'</span></span
                            >
                            <span
                                class="mt-1 block break-words rounded-lg bg-ink/[0.06] px-2.5 py-2 font-mono text-[11px] text-ink-2"
                                >→ 47 rows · 38ms</span
                            >
                        </div>
                        <div
                            class="max-w-[85%] self-start rounded-[18px] rounded-bl-[6px] bg-lavender px-4 py-3 text-sm leading-[1.45] text-ink"
                        >
                            You have <b class="font-medium">47 stale repos</b>.
                            The top three by inactivity: <i>ziglang/zig-old</i>, <i
                                >pkg/example</i
                            >,
                            <i>typicode/lowdb</i>. Want me to unstar all 47?
                        </div>
                        <div
                            class="max-w-[85%] self-end rounded-[18px] rounded-br-[6px] bg-ink px-4 py-3 text-sm leading-[1.45] text-paper"
                        >
                            Yes — and give me a markdown list first.
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-14">
                <h3
                    class="mb-[18px] font-mono text-sm font-medium uppercase tracking-[0.12em] text-ink-3"
                >
                    Works with every MCP client
                </h3>
                <div class="flex flex-wrap gap-2.5">
                    <span
                        class="inline-flex items-center gap-2.5 rounded-full bg-paper px-[18px] py-3 text-sm inset-shadow-hair"
                        ><span class="h-2.5 w-2.5 rounded-full bg-peach-700"
                        ></span>Claude Desktop</span
                    >
                    <span
                        class="inline-flex items-center gap-2.5 rounded-full bg-paper px-[18px] py-3 text-sm inset-shadow-hair"
                        ><span class="h-2.5 w-2.5 rounded-full bg-pistachio-700"
                        ></span>ChatGPT</span
                    >
                    <span
                        class="inline-flex items-center gap-2.5 rounded-full bg-paper px-[18px] py-3 text-sm inset-shadow-hair"
                        ><span class="h-2.5 w-2.5 rounded-full bg-lavender-700"
                        ></span>Cursor</span
                    >
                    <span
                        class="inline-flex items-center gap-2.5 rounded-full bg-paper px-[18px] py-3 text-sm inset-shadow-hair"
                        ><span class="h-2.5 w-2.5 rounded-full bg-sky-700"
                        ></span>TypingMind</span
                    >
                    <span
                        class="inline-flex items-center gap-2.5 rounded-full bg-paper px-[18px] py-3 text-sm inset-shadow-hair"
                        ><span class="h-2.5 w-2.5 rounded-full bg-rose-700"
                        ></span>LibreChat</span
                    >
                    <span
                        class="inline-flex items-center gap-2.5 rounded-full bg-paper px-[18px] py-3 text-sm inset-shadow-hair"
                        ><span class="h-2.5 w-2.5 rounded-full bg-butter-700"
                        ></span>Zed</span
                    >
                    <span
                        class="inline-flex items-center gap-2.5 rounded-full bg-paper px-[18px] py-3 text-sm inset-shadow-hair"
                        ><span class="h-2.5 w-2.5 rounded-full bg-mint-700"
                        ></span>Windsurf</span
                    >
                    <span
                        class="inline-flex items-center gap-2.5 rounded-full bg-paper px-[18px] py-3 text-sm inset-shadow-hair"
                        ><span class="h-2.5 w-2.5 rounded-full bg-ink"></span>+
                        function-calling APIs</span
                    >
                </div>
            </div>
        </div>
    </section>

    <!-- ============ INTEGRATIONS ============ -->
    <section class="overflow-hidden bg-paper py-20" id="integrations">
        <div class="wrap">
            <h3
                class="mb-4 max-w-[16ch] font-display text-[clamp(36px,4vw,52px)] font-normal leading-[1.06] tracking-[-0.03em]"
            >
                Forty-something <em class="italic text-mint-700">sources</em>,
                and counting.
            </h3>
            <p class="mb-10 text-lg text-ink-2">
                All queried the same way. Install only the ones you use.
            </p>
        </div>
        <div
            class="flex w-max gap-3.5 py-2.5 animate-marquee motion-reduce:animate-none"
            id="marquee"
        >
        </div>
        <div
            class="flex w-max gap-3.5 py-2.5 animate-marquee motion-reduce:animate-none"
            id="marquee2"
            style="animation-delay:-24s"
        >
        </div>
        <div class="wrap mt-10 text-center">
            <a class="btn btn-ghost" href="/integrations"
                >Browse all integrations →</a
            >
        </div>
    </section>

    <!-- ============ INSTALL ============ -->
    <section class="bg-paper-3 py-24" id="install">
        <div class="wrap">
            <div
                class="grid grid-cols-1 items-center gap-8 md:grid-cols-2 md:gap-12"
            >
                <div>
                    <span
                        class="font-mono text-xs uppercase tracking-[0.14em] text-ink-3"
                        >Get started</span
                    >
                    <h2
                        class="mt-3.5 mb-6 font-display text-[clamp(36px,4vw,52px)] font-normal leading-[1.06] tracking-[-0.03em]"
                    >
                        One <em class="italic text-rose-700">command</em>,<br
                        />and you're querying.
                    </h2>
                    <p class="max-w-[42ch] text-xl text-ink-2">
                        Pick your OS. We detect your platform but you can flip
                        between them to copy the right command.
                    </p>
                </div>
                <div>
                    <div class="mb-3.5 flex gap-1.5" id="osTabs">
                        <button
                            class="os-tab rounded-full bg-paper px-3.5 py-2 font-ui text-[13px] text-ink-2 inset-shadow-hair on"
                            data-os="mac">macOS</button
                        >
                        <button
                            class="os-tab rounded-full bg-paper px-3.5 py-2 font-ui text-[13px] text-ink-2 inset-shadow-hair"
                            data-os="linux">Linux</button
                        >
                        <button
                            class="os-tab rounded-full bg-paper px-3.5 py-2 font-ui text-[13px] text-ink-2 inset-shadow-hair"
                            data-os="win">Windows</button
                        >
                    </div>
                    <div
                        class="flex items-center justify-between gap-5 rounded-lg bg-ink p-6 font-mono text-[15px] text-paper"
                    >
                        <div class="flex items-start gap-2 overflow-x-auto">
                            <span class="opacity-50">$</span><span
                                id="osCmd"
                                class="whitespace-pre-wrap break-words"
                                >brew install anyquery</span
                            >
                        </div>
                        <button
                            class="shrink-0 cursor-pointer rounded-full border-0 bg-paper/[0.08] px-3.5 py-2 font-ui text-[13px] text-paper transition hover:bg-paper/[0.16]"
                            id="copyBtn">Copy</button
                        >
                    </div>
                    <p class="mt-3 text-sm text-ink-3">
                        Then: <code class="aq-code"
                            >anyquery i github spotify notion</code
                        > to install your first plugins.
                    </p>
                    <a
                        href="/docs/#installation"
                        class="mt-3.5 inline-block text-sm text-ink-3 underline underline-offset-2"
                        >See every install option →</a
                    >
                </div>
            </div>
        </div>
    </section>
</Main>

<script>
    /* ==============================================================
       Data sources for kinetic hero + result card + playground
       (illustrative sample data)
    ============================================================== */
    type Row = { a: string; b: string; pill: string; p: string };
    type Source = {
        color: string;
        word: string;
        table: string;
        time: string;
        rows: number;
        data: Row[];
        cols: string[];
        pg: string;
    };

    const SOURCES: Record<string, Source> = {
        github: {
            color: "pistachio",
            word: "github",
            table: "github_starred_repos",
            time: "27ms",
            rows: 274,
            data: [
                { a: "tldraw/tldraw", b: "★ 36.9k", pill: "MIT", p: "sky" },
                {
                    a: "anthropics/mcp",
                    b: "★ 8.2k",
                    pill: "Apache",
                    p: "lavender",
                },
                { a: "rauchg/slackin", b: "★ 5.3k", pill: "MIT", p: "sky" },
                { a: "sst/sst", b: "★ 22.1k", pill: "MIT", p: "sky" },
                { a: "vercel/next.js", b: "★ 121k", pill: "MIT", p: "sky" },
                {
                    a: "astral-sh/uv",
                    b: "★ 30.8k",
                    pill: "Apache",
                    p: "lavender",
                },
            ],
            cols: ["repo", "stars", "license"],
            pg: `-- your starred repos, newest first
SELECT name, stars, license
FROM github_starred_repos
WHERE owner = 'you'
ORDER BY starred_at DESC;`,
        },
        notion: {
            color: "peach",
            word: "notion",
            table: "notion_database",
            time: "54ms",
            rows: 128,
            data: [
                { a: "Q2 OKRs", b: "In progress", pill: "High", p: "rose" },
                {
                    a: "Hiring pipeline",
                    b: "Done",
                    pill: "Low",
                    p: "pistachio",
                },
                { a: "Design review", b: "Blocked", pill: "High", p: "rose" },
                {
                    a: "Launch post",
                    b: "Not started",
                    pill: "Med",
                    p: "butter",
                },
                {
                    a: "Runbook audit",
                    b: "In progress",
                    pill: "Med",
                    p: "butter",
                },
                {
                    a: "Customer interviews",
                    b: "Done",
                    pill: "Low",
                    p: "pistachio",
                },
            ],
            cols: ["task", "status", "priority"],
            pg: `-- update the priority on an active Notion page
UPDATE notion_tasks
SET priority = 'High'
WHERE status = 'Blocked';`,
        },
        spotify: {
            color: "lavender",
            word: "spotify",
            table: "spotify_saved_tracks",
            time: "45ms",
            rows: 819,
            data: [
                { a: "Bladee — Disco", b: "2:14", pill: "2021", p: "lavender" },
                {
                    a: "Fred again.. — Marea",
                    b: "4:03",
                    pill: "2022",
