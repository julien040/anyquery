---
import Main from "../../layouts/main.astro";
import { getCollection } from "astro:content";

const recipes = await getCollection("recipes");
---

<Main title={"Guides - Anyquery"}>
    <h1 class="text-5xl mt-2 font-display text-ink font-normal">
        <em class="text-peach-700">Recipes</em>
    </h1>
    <p class="mb-4 mt-2 text-sm text-black/60">
        I have written {recipes.length} tutorials using computer assistance to help
        you get started with Anyquery. If you have any questions, or would like to
        report a bug, please feel free to contact me of the <a
            href="https://github.com/julien040/anyquery/issues/new"
            class="underline text-lavender-700"
        >
            GitHub issue tracker</a>.
    </p>
    <main
        class="grid
            grid-cols-1
            md:grid-cols-2
            gap-4"
    >
        {
            recipes.map((guide) => (
                <a
                    class="flex flex-col p-6 bg-white/30 rounded-md border border-black/10 hover:bg-white/70 transition"
                    href={`/recipes/${guide.slug}`}
                >
                    <h2 class="text-xl mt-0 font-display">{guide.data.title}</h2>
                    <p class="text-black/60 text-sm">
                        {guide.data.description}
                    </p>
                </a>
            ))
        }
    </main>
</Main>
